{
  "name": "hta-oman",
  "version": "2.0.0",
  "description": "Oman HTA Platform - Health Technology Assessment Application",
  "main": "index.html",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write \"src/**/*.js\" \"*.json\" \"*.md\"",
    "format:check": "prettier --check \"src/**/*.js\"",
    "validate": "npm run lint && npm run test",
    "build": "node scripts/build.js",
    "serve": "npx serve .",
    "start": "npx serve . -p 3000",
    "check-syntax": "for f in src/**/*.js; do node -c \"$f\" || exit 1; done",
    "audit": "npm audit --audit-level=moderate",
    "prepare": "husky install || true"
  },
  "keywords": [
    "hta",
    "health-economics",
    "markov",
    "meta-analysis",
    "cost-effectiveness",
    "oman",
    "gcc",
    "pharmacoeconomics",
    "budget-impact",
    "psa",
    "cheers"
  ],
  "author": "HTA Artifact Standard Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/oman-moh/hta-platform.git"
  },
  "bugs": {
    "url": "https://github.com/oman-moh/hta-platform/issues"
  },
  "homepage": "https://github.com/oman-moh/hta-platform#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "@types/jest": "^29.5.12",
    "fast-check": "^3.15.0",
    "serve": "^14.2.0"
  },
  "lint-staged": {
    "src/**/*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "jest": {
    "testEnvironment": "jsdom",
    "roots": ["<rootDir>/tests"],
    "collectCoverageFrom": ["src/**/*.js"],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    },
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  }
}
