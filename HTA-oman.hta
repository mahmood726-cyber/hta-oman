<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Oman HTA Platform</title>
    <hta:application
        id="htaApp"
        applicationName="Oman HTA Platform"
        border="thin"
        caption="yes"
        maximizeButton="yes"
        minimizeButton="yes"
        showInTaskbar="yes"
        sysMenu="yes"
        scroll="no"
        singleInstance="yes"
    />
    <style>
        html, body {
            height: 100%;
            width: 100%;
            margin: 0;
            overflow: hidden;
        }

        #app-frame {
            border: 0;
            height: 100%;
            width: 100%;
        }
    </style>
</head>
<body>
    <iframe id="app-frame" src="index.html" title="Oman HTA Platform"></iframe>
</body>
</html>
